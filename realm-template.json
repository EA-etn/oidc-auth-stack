{
  "realm": "myrealm",
  "enabled": true,

  "clients": [
    {
      "clientId": "oauth2-proxy",
      "name": "OAuth2 Proxy Client",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "${OAUTH2_PROXY_CLIENT_SECRET}",
      "redirectUris": [
        "http://${HOST_IP}:8088/oauth2/callback"
      ],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],

  "users": [
    {
      "username": "${USERNAME}",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "testuser@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "${PASSWORD}",
          "temporary": false
        }
      ]
    }
  ]
}
